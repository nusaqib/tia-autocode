FUNCTION "Scale" : Real
{ S7_Optimized_Access := 'TRUE' }
VAR_INPUT
    raw    : Int;    // 0..27648 raw analog value
    hi_eng : Real;   // engineering value at full scale
    lo_eng : Real;   // engineering value at zero
END_VAR
BEGIN
    #Scale := #lo_eng + (INT_TO_REAL(#raw) / 27648.0) * (#hi_eng - #lo_eng);
END_FUNCTION
